# Stripe Configuration
# Replace with your real keys from https://dashboard.stripe.com/apikeys
# Test keys start with pk_test_ / Live keys start with pk_live_
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Stripe Price IDs — create products in Stripe Dashboard, copy the price IDs here
# Dashboard: https://dashboard.stripe.com/products
VITE_STRIPE_PRICE_STARTER=price_test_starter
VITE_STRIPE_PRICE_DUO=price_test_duo
VITE_STRIPE_PRICE_FAMILY=price_test_family

# Stripe Shipping Rate IDs (optional, comma-separated)
# Create in Dashboard > Settings > Shipping rates
# Example: shr_1abc123,shr_1def456
# If empty, Stripe will still collect shipping address but won't show shipping options
VITE_STRIPE_SHIPPING_RATES=
